# Example .env file — keep this in the repo as a template.
# The real credentials file lives in your OS user-data folder:
#   Windows: %LOCALAPPDATA%\Tastier\.env
#   macOS:   ~/Library/Application Support/Tastier/.env
# Create a personal OAuth grant at my.tastytrade.com -> API.
# Grant only the READ scope.
TT_SECRET=your_client_secret_here
TT_REFRESH=your_refresh_token_here
# paper = cert/sandbox environment, live = production (still read-only)
TT_ENV=paper
PORT=8420

# --- optional: LLM position analysis (the "Get analysis" panel) ---
# Set ONE of these keys; the first present wins unless LLM_PROVIDER is set.
# Keys stay local — the backend calls the provider, the browser never sees them.
#ANTHROPIC_API_KEY=sk-ant-...
#OPENAI_API_KEY=sk-...
#GEMINI_API_KEY=...
#LLM_PROVIDER=anthropic   # anthropic | openai | gemini
#LLM_MODEL=claude-sonnet-5  # optional override per provider
